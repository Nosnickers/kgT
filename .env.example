# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=pwd

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct-v0.3-q4_0
OLLAMA_DEEP_THOUGHT_MODE=false

# Data Configuration
DATA_FILE=data/Apple_Environmental_Progress_Report_2024.md

#Knowledge Processing Configuration
CHUNK_SIZE=2000
CHUNK_OVERLAP=200
MAX_RETRIES=3
RETRY_DELAY=2

# Entity Linking Configuration
ENABLE_ENTITY_LINKING=false
ENTITY_TYPES_TO_LINK=Patient,PatientId

# LLM Logging Configuration
ENABLE_LLM_LOGGING=false

# Embedding Model Configuration
# 设置本地嵌入模型路径，避免每次从 Hugging Face Hub 下载
# 如果不设置此变量，系统将从 Hugging Face Hub 下载模型
# 
# 路径格式说明：
# - Windows: C:/Users/YourName/.cache/huggingface/hub/models--sentence-transformers--all-MiniLM-L6-v2
# - Linux/Mac: /home/yourname/.cache/huggingface/hub/models--sentence-transformers--all-MiniLM-L6-v2
#
# 如何获取本地模型路径：
# 1. 首次运行时，模型会自动下载到 Hugging Face 缓存目录
# 2. 缓存目录通常位于：
#    - Windows: C:/Users/<YourUsername>/.cache/huggingface/hub/
#    - Linux/Mac: ~/.cache/huggingface/hub/
# 3. 在缓存目录中查找 models--sentence-transformers--all-MiniLM-L6-v2 文件夹
# 4. 将完整路径复制到下面的配置中
#
# 支持的模型：
# - all-MiniLM-L6-v2 (默认，384维，轻量级)
# - paraphrase-multilingual-MiniLM-L12-v2 (多语言，384维)
# - all-mpnet-base-v2 (英文，768维，性能更好)
LOCAL_EMBEDDING_MODEL_PATH=C:/Users/<your_path>/.cache/huggingface/hub/models--sentence-transformers--all-MiniLM-L6-v2

# online or local
ENABLE_ONLINE_LLM=false

# Online LLM Configuration (OpenAI-compatible APIs)
ONLINE_LLM_API_KEY=
ONLINE_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ONLINE_LLM_MODEL=qwen3-coder-plus
ONLINE_LLM_TEMPERATURE=0.1
ONLINE_LLM_MAX_TOKENS=4096
ONLINE_LLM_TIMEOUT=30

# Ollama Advanced Configuration (optional)
OLLAMA_TEMPERATURE=0.1
OLLAMA_NUM_CTX=4096

# 是否使用思考模式
OLLAMA_DEEP_THOUGHT_MODE=true
